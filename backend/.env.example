# ============================================================
# AlexisEVT Backend — Variables de entorno
# Copiar este archivo como .env y completar los valores.
# NUNCA commitear el .env con valores reales.
# ============================================================

# ─── JWT (OBLIGATORIO) ───────────────────────────────────────
# Generar con: python3 -c "import secrets; print(secrets.token_hex(64))"
SECRET_KEY=REEMPLAZAR_CON_64_CHARS_ALEATORIOS

# ─── Base de datos ───────────────────────────────────────────
# Opción A — URL completa (dev con SQLite o cualquier motor):
# DATABASE_URL=sqlite:///./local_dev.db

# Opción B — Variables individuales para Hostinger MySQL (prod):
DB_HOST=tu-host.hostinger.com
DB_PORT=3306
DB_USER=tu_usuario_db
DB_PASSWORD=tu_password_db
DB_NAME=tu_nombre_db

# ─── Entorno ─────────────────────────────────────────────────
DEBUG=false

# ─── Imágenes (ADR-001) ──────────────────────────────────────
# Dev: FastAPI las sirve en localhost
# Prod: nginx las sirve desde el filesystem
IMAGES_BASE_URL=https://alexis.iwebtecnology.com/media/images
UPLOAD_DIR=/home/iweb/alexisevt/data/images
SERVE_STATIC_LOCALLY=false

# ─── CORS (ADR-002) ──────────────────────────────────────────
# ALLOWED_ORIGINS solo necesario si agregás soporte en main.py
ALLOWED_ORIGINS=https://alexis.iwebtecnology.com

# ─── SMTP (opcional) ─────────────────────────────────────────
SMTP_HOST=smtp.tuproveedor.com
SMTP_PORT=587
SMTP_USER=noreply@alexisevt.com
SMTP_PASSWORD=tu_password_smtp
SMTP_FROM=noreply@alexisevt.com
SMTP_TLS=true
